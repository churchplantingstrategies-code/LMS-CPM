# ===========================
# DATABASE
# ===========================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ediscipleship"

# ===========================
# NEXTAUTH
# ===========================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-here-change-in-production"

# ===========================
# GOOGLE OAUTH (optional)
# ===========================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ===========================
# PAYMONGO PAYMENTS
# ===========================
# Get keys from: https://dashboard.paymongo.com/developers/api_keys
PAYMONGO_SECRET_KEY="sk_live_your_paymongo_secret_key"
PAYMONGO_PUBLIC_KEY="pk_live_your_paymongo_public_key"

# Webhook signing key for PayMongo webhooks
# Create webhook endpoint at: https://dashboard.paymongo.com/developers/webhooks
PAYMONGO_WEBHOOK_SECRET="whsk_your_paymongo_webhook_secret"

# PayMongo Product IDs (create products in PayMongo Dashboard)
PAYMONGO_PRODUCT_STARTER="prod_starter_id"
PAYMONGO_PRODUCT_GROWTH="prod_growth_id"
PAYMONGO_PRODUCT_PRO="prod_pro_id"

# ===========================
# EMAIL (SendGrid or SMTP)
# ===========================
SENDGRID_API_KEY="SG.your_sendgrid_api_key"
EMAIL_FROM="noreply@ediscipleship.com"
EMAIL_FROM_NAME="eDiscipleship"

# SMTP alternative (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"

# ===========================
# FILE STORAGE (AWS S3 or Cloudflare R2)
# ===========================
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="ediscipleship-media"
AWS_S3_PUBLIC_URL="https://ediscipleship-media.s3.us-east-1.amazonaws.com"

# Cloudflare R2 (alternative)
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
R2_BUCKET="ediscipleship-media"
R2_PUBLIC_URL="https://pub-your-account.r2.dev"

# ===========================
# APP SETTINGS
# ===========================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="eDiscipleship"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
