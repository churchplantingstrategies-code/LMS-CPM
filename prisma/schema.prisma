generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model accounts {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  users             users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model analytics_events {
  id         String   @id
  userId     String?
  sessionId  String?
  event      String
  properties Json?
  ipAddress  String?
  userAgent  String?
  referrer   String?
  createdAt  DateTime @default(now())
  users      users?   @relation(fields: [userId], references: [id])

  @@index([event, createdAt])
}

model assignments {
  id          String        @id
  title       String
  description String
  lessonId    String
  dueDate     DateTime?
  maxScore    Float         @default(100)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  lessons     lessons       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions submissions[]
}

model automation_rules {
  id          String            @id
  name        String
  description String?
  trigger     AutomationTrigger
  conditions  Json?
  actions     Json
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime
}

model certificates {
  id             String   @id
  userId         String
  courseId       String
  certificateUrl String?
  issuedAt       DateTime @default(now())
  courses        courses  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  users          users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model courses {
  id             String           @id
  title          String
  slug           String           @unique
  description    String?
  shortDesc      String?
  thumbnail      String?
  previewVideo   String?
  price          Float?
  isPublished    Boolean          @default(false)
  isFeatured     Boolean          @default(false)
  level          CourseLevel      @default(BEGINNER)
  language       String           @default("English")
  category       String?
  tags           String[]
  duration       Int?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  certificates   certificates[]
  discussions    discussions[]
  enrollments    enrollments[]
  funnel_courses funnel_courses[]
  modules        modules[]
}

model discussions {
  id        String    @id
  title     String
  content   String
  userId    String
  courseId  String
  isPinned  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  courses   courses   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  users     users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies   replies[]
}

model email_campaigns {
  id          String         @id
  title       String
  subject     String
  previewText String?
  content     String
  type        EmailType      @default(BROADCAST)
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  stats       Json?
  tags        String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime
  email_logs  email_logs[]
}

model email_logs {
  id              String          @id
  campaignId      String
  leadId          String?
  userId          String?
  to              String
  status          String          @default("sent")
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  createdAt       DateTime        @default(now())
  email_campaigns email_campaigns @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leads           leads?          @relation(fields: [leadId], references: [id])
  users           users?          @relation(fields: [userId], references: [id])
}

model enrollments {
  id          String           @id
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  expiresAt   DateTime?
  courses     courses          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  users       users            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model funnel_courses {
  funnelId String
  courseId String
  courses  courses @relation(fields: [courseId], references: [id], onDelete: Cascade)
  funnels  funnels @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@id([funnelId, courseId])
}

model funnel_steps {
  id       String         @id
  title    String
  type     FunnelStepType
  order    Int
  content  Json?
  funnelId String
  funnels  funnels        @relation(fields: [funnelId], references: [id], onDelete: Cascade)
}

model funnels {
  id             String           @id
  title          String
  slug           String           @unique
  description    String?
  type           FunnelType       @default(LEAD_CAPTURE)
  isPublished    Boolean          @default(false)
  settings       Json?
  stats          Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  funnel_courses funnel_courses[]
  funnel_steps   funnel_steps[]
  leads          leads[]
}

model leads {
  id         String       @id
  email      String
  name       String?
  phone      String?
  source     String?
  funnelId   String?
  userId     String?
  tags       String[]
  metadata   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  email_logs email_logs[]
  funnels    funnels?     @relation(fields: [funnelId], references: [id])
  users      users?       @relation(fields: [userId], references: [id])
}

model lesson_progress {
  id          String    @id
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  watchedTime Int?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  lessons     lessons   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  users       users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model lessons {
  id              String            @id
  title           String
  slug            String
  description     String?
  content         String?
  videoUrl        String?
  videoProvider   VideoProvider     @default(UPLOAD)
  duration        Int?
  order           Int               @default(0)
  isPublished     Boolean           @default(false)
  isFree          Boolean           @default(false)
  attachments     Json?
  moduleId        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  assignments     assignments[]
  lesson_progress lesson_progress[]
  modules         modules           @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, slug])
}

model modules {
  id          String    @id
  title       String
  description String?
  order       Int       @default(0)
  isPublished Boolean   @default(false)
  courseId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  lessons     lessons[]
  courses     courses   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model payments {
  id                        String        @id
  userId                    String
  amount                    Float
  currency                  String        @default("usd")
  status                    PaymentStatus @default(PENDING)
  type                      PaymentType   @default(SUBSCRIPTION)
  description               String?
  paymongoCheckoutSessionId String?       @unique
  paymongoInvoiceId         String?
  metadata                  Json?
  createdAt                 DateTime      @default(now())
  users                     users         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model plans {
  id                String          @id
  name              String
  slug              String          @unique
  description       String?
  price             Float
  interval          PlanInterval    @default(MONTHLY)
  features          Json
  isActive          Boolean         @default(true)
  isPopular         Boolean         @default(false)
  paymongoProductId String?
  trialDays         Int?            @default(0)
  maxCourses        Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  subscriptions     subscriptions[]
}

model replies {
  id           String      @id
  content      String
  userId       String
  discussionId String
  isInstructor Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  discussions  discussions @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  users        users       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model sessions {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model submissions {
  id           String           @id
  userId       String
  assignmentId String
  content      String
  attachments  Json?
  score        Float?
  feedback     String?
  status       SubmissionStatus @default(SUBMITTED)
  submittedAt  DateTime         @default(now())
  gradedAt     DateTime?
  assignments  assignments      @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  users        users            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model subscriptions {
  id                     String             @id
  userId                 String             @unique
  planId                 String
  status                 SubscriptionStatus @default(ACTIVE)
  paymongoSubscriptionId String?            @unique
  paymongoCustomerId     String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  canceledAt             DateTime?
  trialEnd               DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime
  plans                  plans              @relation(fields: [planId], references: [id])
  users                  users              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model users {
  id               String             @id
  name             String?
  email            String             @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             UserRole           @default(STUDENT)
  bio              String?
  phone            String?
  timezone         String?            @default("UTC")
  isActive         Boolean            @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  accounts         accounts[]
  analytics_events analytics_events[]
  certificates     certificates[]
  discussions      discussions[]
  email_logs       email_logs[]
  enrollments      enrollments[]
  leads            leads[]
  lesson_progress  lesson_progress[]
  payments         payments[]
  replies          replies[]
  sessions         sessions[]
  submissions      submissions[]
  subscriptions    subscriptions?
}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum AutomationTrigger {
  USER_REGISTERED
  USER_SUBSCRIBED
  USER_UNSUBSCRIBED
  LESSON_COMPLETED
  COURSE_COMPLETED
  PAYMENT_RECEIVED
  CHECKOUT_ABANDONED
  LEAD_CAPTURED
  TAG_ADDED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum EmailType {
  BROADCAST
  DRIP
  AUTOMATION
  TRANSACTIONAL
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  SUSPENDED
  EXPIRED
}

enum FunnelStepType {
  LANDING
  OPT_IN
  SALES
  CHECKOUT
  UPSELL
  DOWNSELL
  THANK_YOU
}

enum FunnelType {
  LEAD_CAPTURE
  SALES
  WEBINAR
  COURSE_PROMO
  UPSELL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentType {
  SUBSCRIPTION
  ONE_TIME
  REFUND
}

enum PlanInterval {
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  GRADED
  RETURNED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
  PAUSED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum VideoProvider {
  UPLOAD
  YOUTUBE
  VIMEO
  CLOUDFLARE_STREAM
}
