// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTH MODELS (NextAuth compatible)
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(STUDENT)
  bio           String?
  phone         String?
  timezone      String?   @default("UTC")
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts       Account[]
  sessions       Session[]
  enrollments    Enrollment[]
  lessonProgress LessonProgress[]
  submissions    Submission[]
  discussions    Discussion[]
  replies        Reply[]
  certificates   Certificate[]
  subscription   Subscription?
  payments       Payment[]
  analyticsEvents AnalyticsEvent[]
  leads          Lead[]
  emailLogs      EmailLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==========================================
// COURSE MANAGEMENT
// ==========================================

model Course {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String?      @db.Text
  shortDesc    String?
  thumbnail    String?
  previewVideo String?
  price        Float?
  isPublished  Boolean      @default(false)
  isFeatured   Boolean      @default(false)
  level        CourseLevel  @default(BEGINNER)
  language     String       @default("English")
  category     String?
  tags         String[]
  duration     Int?         // total minutes
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  modules     Module[]
  enrollments Enrollment[]
  discussions Discussion[]
  certificates Certificate[]
  funnels     FunnelCourse[]

  @@map("courses")
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  courseId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("modules")
}

model Lesson {
  id          String       @id @default(cuid())
  title       String
  slug        String
  description String?      @db.Text
  content     String?      @db.Text
  videoUrl    String?
  videoProvider VideoProvider @default(UPLOAD)
  duration    Int?         // minutes
  order       Int          @default(0)
  isPublished Boolean      @default(false)
  isFree      Boolean      @default(false)
  attachments Json?        // array of file URLs
  moduleId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  module      Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  assignments Assignment[]

  @@unique([moduleId, slug])
  @@map("lessons")
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  expiresAt   DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  watchedTime Int?      // seconds watched
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

// ==========================================
// ASSIGNMENTS & DISCUSSIONS
// ==========================================

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  lessonId    String
  dueDate     DateTime?
  maxScore    Float    @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id           String           @id @default(cuid())
  userId       String
  assignmentId String
  content      String           @db.Text
  attachments  Json?
  score        Float?
  feedback     String?          @db.Text
  status       SubmissionStatus @default(SUBMITTED)
  submittedAt  DateTime         @default(now())
  gradedAt     DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

model Discussion {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  userId    String
  courseId  String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  replies Reply[]

  @@map("discussions")
}

model Reply {
  id           String   @id @default(cuid())
  content      String   @db.Text
  userId       String
  discussionId String
  isInstructor Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@map("replies")
}

model Certificate {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  certificateUrl String?
  issuedAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("certificates")
}

// ==========================================
// SUBSCRIPTION & PAYMENTS
// ==========================================

model Plan {
  id                 String       @id @default(cuid())
  name               String
  slug               String       @unique
  description        String?
  price              Float
  interval           PlanInterval @default(MONTHLY)
  features           Json         // array of feature strings
  isActive           Boolean      @default(true)
  isPopular          Boolean      @default(false)
  paymongoProductId  String?
  trialDays          Int?         @default(0)
  maxCourses     Int?         // null = unlimited
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  planId                 String
  status                 SubscriptionStatus @default(ACTIVE)
  paymongoSubscriptionId String?            @unique
  paymongoCustomerId     String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Payment {
  id                       String        @id @default(cuid())
  userId                   String
  amount                   Float
  currency                 String        @default("usd")
  status                   PaymentStatus @default(PENDING)
  type                     PaymentType   @default(SUBSCRIPTION)
  description              String?
  paymongoCheckoutSessionId String?      @unique
  paymongoInvoiceId        String?
  metadata             Json?
  createdAt            DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ==========================================
// MARKETING FUNNELS
// ==========================================

model Funnel {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String?
  type        FunnelType  @default(LEAD_CAPTURE)
  isPublished Boolean     @default(false)
  settings    Json?
  stats       Json?       // { visits, leads, conversions }
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  steps   FunnelStep[]
  leads   Lead[]
  courses FunnelCourse[]

  @@map("funnels")
}

model FunnelStep {
  id       String          @id @default(cuid())
  title    String
  type     FunnelStepType
  order    Int
  content  Json?           // page builder JSON
  funnelId String

  funnel Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@map("funnel_steps")
}

model FunnelCourse {
  funnelId String
  courseId String

  funnel Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([funnelId, courseId])
  @@map("funnel_courses")
}

model Lead {
  id        String   @id @default(cuid())
  email     String
  name      String?
  phone     String?
  source    String?
  funnelId  String?
  userId    String?
  tags      String[]
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  funnel    Funnel?       @relation(fields: [funnelId], references: [id])
  user      User?         @relation(fields: [userId], references: [id])
  emailLogs EmailLog[]

  @@map("leads")
}

// ==========================================
// EMAIL & AUTOMATION
// ==========================================

model EmailCampaign {
  id          String         @id @default(cuid())
  title       String
  subject     String
  previewText String?
  content     String         @db.Text
  type        EmailType      @default(BROADCAST)
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  stats       Json?          // { sent, opened, clicked, bounced }
  tags        String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  emailLogs EmailLog[]

  @@map("email_campaigns")
}

model EmailLog {
  id         String   @id @default(cuid())
  campaignId String
  leadId     String?
  userId     String?
  to         String
  status     String   @default("sent")
  openedAt   DateTime?
  clickedAt  DateTime?
  bouncedAt  DateTime?
  createdAt  DateTime @default(now())

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead?         @relation(fields: [leadId], references: [id])
  user     User?         @relation(fields: [userId], references: [id])

  @@map("email_logs")
}

model AutomationRule {
  id          String          @id @default(cuid())
  name        String
  description String?
  trigger     AutomationTrigger
  conditions  Json?
  actions     Json            // array of action objects
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("automation_rules")
}

// ==========================================
// ANALYTICS
// ==========================================

model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?
  event      String
  properties Json?
  ipAddress  String?
  userAgent  String?
  referrer   String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([event, createdAt])
  @@map("analytics_events")
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum VideoProvider {
  UPLOAD
  YOUTUBE
  VIMEO
  CLOUDFLARE_STREAM
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  SUSPENDED
  EXPIRED
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  GRADED
  RETURNED
}

enum PlanInterval {
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
  PAUSED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentType {
  SUBSCRIPTION
  ONE_TIME
  REFUND
}

enum FunnelType {
  LEAD_CAPTURE
  SALES
  WEBINAR
  COURSE_PROMO
  UPSELL
}

enum FunnelStepType {
  LANDING
  OPT_IN
  SALES
  CHECKOUT
  UPSELL
  DOWNSELL
  THANK_YOU
}

enum EmailType {
  BROADCAST
  DRIP
  AUTOMATION
  TRANSACTIONAL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

enum AutomationTrigger {
  USER_REGISTERED
  USER_SUBSCRIBED
  USER_UNSUBSCRIBED
  LESSON_COMPLETED
  COURSE_COMPLETED
  PAYMENT_RECEIVED
  CHECKOUT_ABANDONED
  LEAD_CAPTURED
  TAG_ADDED
}
